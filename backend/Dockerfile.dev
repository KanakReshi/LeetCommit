FROM node:22-alpine

WORKDIR /app

# Copy dependency definitions
COPY package.json package-lock.json* ./

# Install dependencies
RUN npm install

# Copy Prisma schema and generate client
COPY prisma ./prisma/
RUN npx prisma generate

# Expose API port
EXPOSE 3000

# We mount the rest of the code via docker-compose volumes for hot reloading
CMD ["npm", "run", "dev"]
