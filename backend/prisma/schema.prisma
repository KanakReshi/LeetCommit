generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Entities ─────────────────────────────────────────────────────────────

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash   String?
  githubId       String?      @unique
  githubUsername String?
  githubToken    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  submissions    Submission[]
  snapshots      Snapshot[]
  refreshTokens  RefreshToken[]

  @@map("users")
}

model Problem {
  id         String   @id @default(uuid())
  titleSlug  String   @unique
  title      String
  difficulty String   @default("Unknown") // Easy, Medium, Hard
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  submissions   Submission[]
  problemTopics ProblemTopic[]

  @@index([difficulty])
  @@map("problems")
}

model Submission {
  id           String   @id @default(uuid())
  submissionId String   @unique // LeetCode's submission ID
  userId       String
  problemId    String
  
  language     String
  code         String   @db.Text
  runtime      String?
  memory       String?
  status       String   @default("Accepted")
  
  timestamp    DateTime // When it was submitted on LeetCode
  createdAt    DateTime @default(now()) // When it was saved to our DB

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem      Problem  @relation(fields: [problemId], references: [id], onDelete: Restrict)

  // Indexes for analytics: 
  // 1. Grouping by user and problem (e.g., how many attempts per problem)
  // 2. Time-series analysis (e.g., submissions per day)
  // 3. Language grouping
  @@index([userId, problemId])
  @@index([timestamp(sort: Desc)])
  @@index([language])
  @@map("submissions")
}

model Topic {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  problemTopics ProblemTopic[]

  @@map("topics")
}

// Explicit Many-to-Many join table for extensibility and cleaner analytics queries
model ProblemTopic {
  problemId String
  topicId   String

  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  topic     Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([problemId, topicId])
  @@index([topicId]) // Helps finding all problems for a specific topic
  @@map("problem_topics")
}

model Snapshot {
  id        String   @id @default(uuid())
  userId    String
  
  // JSONB is ideal for scalable, flexible analytics data 
  // (e.g., daily stats: { totalSolved: 100, easy: 50, medium: 40, hard: 10 })
  data      Json     @db.JsonB
  
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexing by user and time for efficient chronological analytics retrieval
  @@index([userId, createdAt(sort: Desc)])
  @@map("snapshots")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@map("refresh_tokens")
}
