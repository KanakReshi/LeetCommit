# Environment Setup
PORT=3000
NODE_ENV=development

# Authentication
# Run `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"` to generate a secure secret
JWT_SECRET=super_secret_jwt_key_change_me_in_production
JWT_EXPIRES_IN=7d

# Database Connection
# Replace with your actual PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/leetcommit?schema=public"
